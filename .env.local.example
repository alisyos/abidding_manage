# ─────────────────────────────────────────────────────────────
# Supabase
# Supabase 프로젝트 생성 후 Settings → API에서 복사
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# service_role 키는 서버에서만 사용. 절대 클라이언트에 노출 금지.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─────────────────────────────────────────────────────────────
# SMTP (이메일 발송용 — 회사 메일 서버)
# ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.your-company.co.kr
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@your-company.co.kr
SMTP_PASS=your-smtp-password
SMTP_FROM="DMP코리아 <noreply@your-company.co.kr>"

# ─────────────────────────────────────────────────────────────
# App
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
